# Archivos que NO se publican como assets del sitio (Cloudflare).
.git/
.github/
.claude/
node_modules/
.wrangler/
excel/
worker/
referencias/
# La app carga examples/portico_simple.s3d al iniciar → NO excluir la carpeta;
# solo el artefacto de prueba pesado.
examples/portico_simple_v3.s3d
*.md
*.log
.dev.vars
.gitignore
.assetsignore
wrangler.jsonc
package*.json
# Herramientas del asistente que no deben servirse (sí se sirven reglas.json y los .csv)
asistente/*.mjs
asistente/ficha.schema.json
asistente/n8n_flujo.json
